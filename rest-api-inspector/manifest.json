{
  "manifest_version": 3,
  "name": "Rest API Inspector",
  "version": "2.0.0",
  "description": "Inspect, filter and export REST API calls from any web app. View headers, payloads, timing and status. Export as HAR or JSON.",
  "permissions": [
    "tabs",
    "activeTab"
  ],
  "host_permissions": ["<all_urls>"],
  "minimum_chrome_version": "92",
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "Rest API Inspector"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_start",
      "all_frames": true,
      "world": "MAIN"
    },
    {
      "matches": ["<all_urls>"],
      "js": ["bridge.js"],
      "run_at": "document_start",
      "all_frames": true
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
